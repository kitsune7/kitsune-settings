{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git pull:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr comments:*)",
      "Bash(gh api graphql -f query:*)",
      "Bash(save)",
      "Bash(uv run:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Read(~/.zshrc)",
      "Read(~/.local-scripts)",
      "WebFetch(domain:github.com)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "filesystem": {
      "allowWrite": ["~/Git", "/tmp/build", "~/.local-scripts"]
    }
  }
}